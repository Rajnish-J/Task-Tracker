# Postgres connection string (Neon). Use the POOLED connection URL for the app.
# In Vercel: Project Settings → Environment Variables → add DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# better-auth secret (random string). Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
# Base URL of the app. Use the deployed URL in production.
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth client credentials (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID, type "Web application").
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

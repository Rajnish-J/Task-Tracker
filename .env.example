# Postgres connection string (Neon). Use the POOLED connection URL for the app.
# In Vercel: Project Settings → Environment Variables → add DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# better-auth secret (random string). Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
# Base URL of the app. MUST match the domain the app is served from, with NO
# trailing slash. Local: http://localhost:3000. In production set this in the
# host's env (e.g. Vercel Project Settings -> Environment Variables) to the
# deployed URL, e.g. https://task-tracker-gray-mu.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth client credentials (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID, type "Web application").
#
# better-auth's Google callback is <BETTER_AUTH_URL>/api/auth/callback/google.
# Register EVERY environment's callback under the client's
# "Authorized redirect URIs" (exact match), otherwise Google returns
# Error 400: redirect_uri_mismatch:
#   http://localhost:3000/api/auth/callback/google              (local dev)
#   https://task-tracker-gray-mu.vercel.app/api/auth/callback/google  (prod)
# And add the origins under "Authorized JavaScript origins":
#   http://localhost:3000
#   https://task-tracker-gray-mu.vercel.app
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic API key for the in-app chat assistant (console.anthropic.com ->
# API keys). The chat endpoints return 503 with a friendly message when unset.
ANTHROPIC_API_KEY=""
# Claude model used by the chat assistant. Defaults to claude-opus-4-8 when
# unset. Alternatives: claude-sonnet-5 (cheaper), claude-haiku-4-5 (cheapest).
ANTHROPIC_MODEL="claude-opus-4-8"
